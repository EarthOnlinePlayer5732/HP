# Copy to .env and fill in. model_openai.py auto-loads it.

# OpenAI-compatible endpoint (default model deepseek-v4-flash, CNY-priced)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# MiniMax-M3 via OpenCode Go Anthropic-compatible endpoint (USD-priced)
OPENCODE_API_KEY=
# optional endpoint overrides:
# OPENCODE_GO_BASE_URL=
# OPENCODE_BASE_URL=

# MiniMax-M3 extended thinking (optional):
#   MINIMAX_THINKING=1                 # enable extended thinking
#   MINIMAX_THINKING_BUDGET=           # optional explicit budget; unset = ~window minus 4096
#   MINIMAX_HARD_TIMEOUT=1800          # watchdog seconds (raise for long thinking calls)
